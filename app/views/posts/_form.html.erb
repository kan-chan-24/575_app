<div class="Caution">
  <h4>ひらがな・カタカナ・数字（全角半角OK）のみ、お使いください</h4>
  <h4>字余り・字足らずともに、1音までOKです</h4>
</div>

<%= form_with(model: post, class: "tanzaku-form", data: { controller: "morae-counter", action: "submit->morae-counter#preventDoubleSubmit" }) do |form| %>
  <!-- エラーメッセージ処理 -->
  <% if post.errors.any? %>
    <div class="error-messages">
      <ul>
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  
  <div class="input-area">
    <div class="tanzaku-content">
      <div class="tanzaku-line">
        <%= form.label :top, "上の句", class: "tanzaku-label", style: "display:inline" %>
        <%= form.text_field :top, 
            class: "tanzaku-input",
            data: { 
              morae_counter_target: "top",
              action: "input->morae-counter#onInput"
            } %>
        <span data-morae-counter-target="topCount"><%= post.morae_count(:top) %>音</span>
      </div>

      <div class="tanzaku-line">
        <%= form.label :middle, "中の句", class: "tanzaku-label", style: "display:inline" %>
        <%= form.text_field :middle, 
            class: "tanzaku-input",
            data: { 
              morae_counter_target: "middle",
              action: "input->morae-counter#onInput"
            } %>
        <span data-morae-counter-target="middleCount"><%= post.morae_count(:middle) %>音</span>
      </div>

      <div class="tanzaku-line">
        <%= form.label :bottom, "下の句", class: "tanzaku-label", style: "display:inline" %>
        <%= form.text_field :bottom, 
            class: "tanzaku-input",
            data: { 
              morae_counter_target: "bottom",
              action: "input->morae-counter#onInput"
            } %>
        <span data-morae-counter-target="bottomCount"><%= post.morae_count(:bottom) %>音</span>
      </div>
    </div>
    
    <div class="guide-comment">
      <%= form.label :guide, "解説", class: "guide-label" %>
      <%= form.text_area :guide, class: "guide-input", rows: 4, cols: 50, maxlength: 50, placeholder: "この投稿の解説を50字以内で入力できます" %>
    </div>
  </div>

  <div class="submit-area">
    <%= form.submit '投稿', 
        class: "floating-action-button", 
        style: "left:30px",
        data: { morae_counter_target: "submit" } %>
  </div>
<% end %>