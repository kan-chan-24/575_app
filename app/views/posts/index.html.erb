<h1>投稿一覧</h1>

<% if @posts.present? %>
    <div class="tanzaku-container">
        <% @posts.each do |post| %>
            <%= link_to post, class: "tanzaku-link" do %>
                <div class="tanzaku">
                    <div class="tanzaku-text">
                        <p><%= post.top %></p>
                        <p><%= post.middle %></p>
                        <p><%= post.bottom %></p>
                    </div>
                </div>
            <% end %>
        <% end %>
    </div>
<% else %>
    <p>まだ投稿がありません。</p>
<% end %>
